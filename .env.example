# Copy to `.env.local` and adjust for your environment.
# Only NEXT_PUBLIC_* values are exposed to the browser.

# Absolute URL of the backend GraphQL endpoint.
# Must be absolute (not a relative path) so server-side rendering can reach it.
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3000/graphql

# Origin of the API, used to build URLs for files served at /uploads/<storageKey>
# and to POST binaries to /files/upload.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
